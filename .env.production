# ============================================
# VORTEX HUB - Production Environment
# ============================================

# Environment: development, staging, production
ENVIRONMENT=production

# ============================================
# DATABASE
# ============================================
# Use your production database URL
DATABASE_URL=postgresql://vortex_user:vortex_password@prod-db-host:5432/vortex_hub_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_PRE_PING=true

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Generate a secure random secret in production
# python: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secure-production-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# ============================================
# CORS - Allowed Origins (Production)
# ============================================
# Explicitly allow only your Netlify domain in production
CORS_ORIGINS=["https://vortex-frame-studio1-hub.netlify.app"]

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=https://your-backend-api-url.com
VITE_WS_URL=wss://your-backend-api-url.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=WARNING

# ============================================
# DEBUG & SECURITY
# ============================================
# IMPORTANT: Set to false in production
DEBUG=false
