# ============================================
# VORTEX HUB - Environment Configuration
# ============================================

# Environment: development, staging, production
ENVIRONMENT=development

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://vortex_user:vortex_password@localhost:5432/vortex_hub
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_PRE_PING=true

#---- ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: In production, generate a secure random secret
# python: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secure-random-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# ============================================
# CORS - Allowed Origins
# ============================================
# For production, specify exact domains
# Format as JSON array string
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# DEBUG & SECURITY
# ============================================
# IMPORTANT: Set to false in production
DEBUG=false

# ============================================
# PRODUCTION SETTINGS (Uncomment for production)
# ============================================
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# DATABASE_URL=postgresql://prod_user:SECURE_PASSWORD@prod-db.example.com:5432/vortex_hub
# JWT_SECRET=YOUR_SECURE_RANDOM_SECRET
# CORS_ORIGINS=["https://yourdomain.com"]
# VITE_API_URL=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com
